# ─────────────────────────────────────────────────────────────
# Frontend — safe to expose (compiled into the client bundle)
# ─────────────────────────────────────────────────────────────
# Leave these blank to run the app in DEMO MODE (no backend needed).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# Provider keys — SERVER-SIDE ONLY (never exposed to the browser).
#
# LOCAL DEV: copy this file to `.env` and paste your key(s) below, then
#   restart `npm run dev`. The Vite dev server (dev-api/) does the recognition
#   in-process — your key stays on the Mac, not in the client bundle. With just
#   ANTHROPIC_API_KEY set you'll see the real title/artist over the demo world;
#   add BLOCKADE_LABS_API_KEY to also generate the 360° world.
#
# PRODUCTION: set these as Edge Function secrets instead
#   (`supabase secrets set ANTHROPIC_API_KEY=...`).
#
# If no recognition key is present, the app falls back to the demo panorama so
# the full loop still works.
# ─────────────────────────────────────────────────────────────

# Which vision provider recognizes the artwork: claude | gemini | openai
RECOGNITION_PROVIDER=claude

# Anthropic Claude (default recognizer)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini (alternate recognizer)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# OpenAI / ChatGPT (alternate recognizer)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Panorama generator: blockade | pollinations | comfyui
#   blockade     — best quality, artwork-faithful seamless skyboxes + a FREE depth
#                  map for parallax (API needs a paid plan)
#   pollinations — KEYLESS hosted (no signup); text-only (ignores the artwork),
#                  low-res / soft. Depth is computed in-browser instead.
#   comfyui      — your own local ComfyUI server: keyless, sharp, slower (see README)
PANORAMA_PROVIDER=blockade
BLOCKADE_LABS_API_KEY=

# How Blockade conditions on the artwork:
#   init  (default) — init_image + low init_strength: preserves the artwork's
#                     PALETTE and composition (most faithful).
#   remix           — control_image + remix: keeps composition but DROPS colour.
BLOCKADE_MODE=init
# Lower = stronger artwork influence (Blockade's scale is inverted; ~0.11–0.35).
BLOCKADE_INIT_STRENGTH=0.25

# ComfyUI (when PANORAMA_PROVIDER=comfyui) — runs locally on your machine:
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_CKPT=sd_xl_base_1.0.safetensors
# Optional: a specific Skybox style id. If blank, the function picks a Model-3
# style from GET /skybox/styles at runtime (Model 3 returns the free depth map;
# Model 4 does not). Depth → in-browser parallax (6DoF-lite); no extra cost.
BLOCKADE_SKYBOX_STYLE_ID=

# Supabase service role (DB writes + Storage uploads from Edge Functions).
# SUPABASE_URL is injected automatically in the Supabase runtime.
SUPABASE_SERVICE_ROLE_KEY=
