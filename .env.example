# ─────────────────────────────────────────────────────────────
# Frontend — safe to expose (compiled into the client bundle)
# ─────────────────────────────────────────────────────────────
# Leave these blank to run the app in DEMO MODE (no backend needed).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# Edge Function secrets — SERVER-SIDE ONLY.
# Set these with `supabase secrets set ...`, never in the client.
# If recognition keys are absent the `scan` function short-circuits
# to the bundled demo panorama so the full loop still works.
# ─────────────────────────────────────────────────────────────

# Which vision provider recognizes the artwork: claude | gemini | openai
RECOGNITION_PROVIDER=claude

# Anthropic Claude (default recognizer)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini (alternate recognizer)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI / ChatGPT (alternate recognizer)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Panorama generator: blockade (others can be added behind PanoramaProvider)
PANORAMA_PROVIDER=blockade
BLOCKADE_LABS_API_KEY=
# Optional: a specific Skybox style id. If blank, the function picks one
# from GET /skybox/styles at runtime.
BLOCKADE_SKYBOX_STYLE_ID=

# Supabase service role (DB writes + Storage uploads from Edge Functions).
# SUPABASE_URL is injected automatically in the Supabase runtime.
SUPABASE_SERVICE_ROLE_KEY=
